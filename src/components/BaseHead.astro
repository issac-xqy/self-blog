---
export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
  type?: "website" | "article";
  pubDate?: Date;
  tags?: string[];
}

const {
  title,
  description,
  ogImage = "/og/default.png",
  canonicalURL,
  type = "website",
  pubDate,
  tags = [],
} = Astro.props;

import { SITE } from "../site.config.ts";

const site = Astro.site;
const fullTitle = `${title} | ${SITE.title}`;
---

<meta charset="utf-8" />
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="canonical" href={canonicalURL} />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />

<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:image" content={new URL(ogImage, site).href} />
<meta property="og:site_name" content={SITE.title} />
{canonicalURL && <meta property="og:url" content={canonicalURL} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(ogImage, site).href} />

{type === "article" && pubDate && (
  <meta property="article:published_time" content={pubDate.toISOString()} />
)}
{type === "article" && tags.length > 0 && (
  tags.map((t) => <meta property="article:tag" content={t} />)
)}

<link rel="sitemap" href={new URL("/sitemap-index.xml", site).href} />
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${SITE.title} RSS`}
  href={new URL("/rss.xml", site).href}
/>
