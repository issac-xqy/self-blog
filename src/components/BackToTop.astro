<button
  id="back-to-top"
  class="no-print fixed bottom-6 right-6 z-50 flex h-11 w-11 items-center justify-center rounded-full border border-gray-200 bg-white/80 text-gray-500 opacity-0 shadow-lg backdrop-blur transition-all duration-300 hover:-translate-y-0.5 hover:border-accent hover:text-accent pointer-events-none dark:border-gray-700 dark:bg-gray-900/80 dark:text-gray-400 dark:hover:border-accent-dark dark:hover:text-accent-dark"
  aria-label="回到顶部"
>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M18 15l-6-6-6 6"/>
  </svg>
</button>

<script>
  const btn = document.getElementById("back-to-top");
  let ticking = false;

  window.addEventListener("scroll", () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        const show = window.scrollY > 400;
        if (show) {
          btn.style.opacity = "1";
          btn.style.pointerEvents = "auto";
        } else {
          btn.style.opacity = "0";
          btn.style.pointerEvents = "none";
        }
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });

  btn.addEventListener("click", () => {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });
</script>
