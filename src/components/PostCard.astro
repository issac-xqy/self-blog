---
import type { Post } from "../content/index.ts";
import { postSlug } from "../content/index.ts";
import { formatDate } from "../utils/date";
import TagBadge from "./TagBadge.astro";

export interface Props {
  post: Post;
  index?: number;
}

const { post, index = 0 } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const href = `/blog/${postSlug(post)}/`;

// Deterministic color from post title
const hues = ["#2563eb", "#7c3aed", "#db2777", "#059669", "#d97706", "#0891b2", "#4f46e5", "#be123c"];
const hue = hues[index % hues.length];
---

<article
  class="card group mb-5 flex flex-col gap-3 sm:flex-row sm:gap-6"
  style="animation-delay: {index * 0.06}s;"
>
  <!-- Decorative date bar -->
  <div class="flex shrink-0 items-start gap-3 sm:w-28 sm:flex-col sm:gap-1">
    <div class="mt-1.5 h-1.5 w-1.5 rounded-full shrink-0" style="background:{hue};"></div>
    <time
      datetime={pubDate.toISOString()}
      class="text-xs text-gray-400 dark:text-gray-500 whitespace-nowrap"
    >
      {formatDate(pubDate)}
    </time>
  </div>

  <!-- Content -->
  <div class="min-w-0 flex-1">
    <a href={href} class="no-underline">
      <h2 class="text-lg font-semibold tracking-tight text-gray-900 transition-colors duration-200 group-hover:text-accent dark:text-gray-100 dark:group-hover:text-accent-dark">
        {title}
      </h2>
    </a>
    <p class="mt-1.5 line-clamp-2 text-sm leading-relaxed text-gray-500 dark:text-gray-400">
      {description}
    </p>
    {
      tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {tags.map((tag) => <TagBadge tag={tag} />)}
        </div>
      )
    }
  </div>
</article>
