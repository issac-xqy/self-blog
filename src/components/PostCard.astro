---
import type { Post } from "../content/index.ts";
import { postSlug } from "../content/index.ts";
import { formatDate } from "../utils/date";
import TagBadge from "./TagBadge.astro";

export interface Props {
  post: Post;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const href = `/blog/${postSlug(post)}/`;
---

<article class="post-card border-b border-gray-200 py-8 last:border-0 dark:border-gray-800">
  <a href={href} class="no-underline">
    <h2 class="post-card-title text-xl font-semibold tracking-tight text-gray-900 transition-colors dark:text-gray-100">
      {title}
    </h2>
  </a>
  <p class="mt-2 text-sm leading-relaxed text-gray-500 dark:text-gray-400">
    {description}
  </p>
  <div class="mt-3 flex flex-wrap items-center gap-2 text-xs text-gray-400 dark:text-gray-500">
    <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
    {
      tags.length > 0 && (
        <span class="flex flex-wrap gap-1.5">
          {tags.map((tag) => <TagBadge tag={tag} />)}
        </span>
      )
    }
  </div>
</article>
