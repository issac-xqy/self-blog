---
import { SITE } from "../site.config.ts";

const nav = [
  { label: "首页", href: "/" },
  { label: "文章", href: "/blog/" },
  { label: "标签", href: "/tags/" },
  { label: "关于", href: "/about/" },
];
---

<header class="glass sticky top-0 z-40 border-b border-gray-200/60 dark:border-gray-800/60" id="site-header">
  <nav class="container-blog flex items-center justify-between py-3">
    <a href="/" class="text-lg font-bold tracking-tight text-gray-900 no-underline transition-opacity hover:opacity-75 dark:text-gray-100">
      {SITE.title}
    </a>
    <div class="flex items-center gap-3">
      <ul class="hidden sm:flex items-center gap-1 text-sm">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class="rounded-lg px-3 py-1.5 text-gray-600 no-underline transition-all duration-200 hover:bg-gray-100 hover:text-accent dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-accent-dark"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <button
        id="theme-toggle"
        class="no-print ml-1 rounded-lg p-2 text-gray-500 transition-all duration-300 hover:rotate-12 hover:bg-gray-100 hover:text-accent dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-accent-dark"
        aria-label="切换暗色模式"
        title="切换暗色模式"
      >
        <span class="dark:hidden">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </span>
        <span class="hidden dark:inline">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </span>
      </button>
      <!-- Mobile nav toggle (hidden on desktop) -->
      <button
        id="mobile-nav-toggle"
        class="rounded-lg p-2 text-gray-500 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 sm:hidden"
        aria-label="菜单"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile nav dropdown -->
  <div id="mobile-nav" class="hidden border-t border-gray-200/60 px-4 pb-3 pt-2 dark:border-gray-800/60 sm:hidden">
    <ul class="flex flex-col gap-1">
      {nav.map((item) => (
        <li>
          <a
            href={item.href}
            class="block rounded-lg px-3 py-2 text-sm text-gray-600 no-underline transition-colors hover:bg-gray-100 hover:text-accent dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-accent-dark"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const el = document.documentElement;
    el.classList.toggle("dark");
    localStorage.setItem("theme", el.classList.contains("dark") ? "dark" : "light");
  });

  document.getElementById("mobile-nav-toggle")?.addEventListener("click", () => {
    document.getElementById("mobile-nav")?.classList.toggle("hidden");
  });
</script>
