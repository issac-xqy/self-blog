---
import { SITE } from "../site.config.ts";

const nav = [
  { label: "首页", href: "/" },
  { label: "文章", href: "/blog/" },
  { label: "标签", href: "/tags/" },
  { label: "关于", href: "/about/" },
];
---

<header class="border-b border-gray-200 dark:border-gray-800">
  <nav class="container-blog flex items-center justify-between py-4">
    <a href="/" class="text-lg font-bold tracking-tight no-underline">
      {SITE.title}
    </a>
    <div class="flex items-center gap-4">
      <ul class="flex items-center gap-6 text-sm">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-gray-600 no-underline transition-colors hover:text-accent dark:text-gray-400 dark:hover:text-accent-dark"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <button
        id="theme-toggle"
        class="no-print ml-2 rounded p-1 text-gray-500 transition-colors hover:text-accent dark:text-gray-400 dark:hover:text-accent-dark"
        aria-label="切换暗色模式"
      >
        <span class="dark:hidden">🌙</span>
        <span class="hidden dark:inline">☀️</span>
      </button>
    </div>
  </nav>
</header>
<script>
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const el = document.documentElement;
    el.classList.toggle("dark");
    localStorage.setItem("theme", el.classList.contains("dark") ? "dark" : "light");
  });
</script>
