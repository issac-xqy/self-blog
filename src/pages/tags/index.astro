---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllTags, tagSlug } from "../../content/index.ts";

const tags = await getAllTags();
const maxCount = tags.length > 0 ? Math.max(...tags.map((t) => t.count)) : 1;

const gradientStyles = [
  "background: linear-gradient(135deg, #2563eb, #06b6d4);",
  "background: linear-gradient(135deg, #7c3aed, #ec4899);",
  "background: linear-gradient(135deg, #059669, #14b8a6);",
  "background: linear-gradient(135deg, #ea580c, #f59e0b);",
  "background: linear-gradient(135deg, #dc2626, #f43f5e);",
  "background: linear-gradient(135deg, #4f46e5, #818cf8);",
  "background: linear-gradient(135deg, #0284c7, #38bdf8);",
  "background: linear-gradient(135deg, #9333ea, #c084fc);",
];

function tagGradient(tag: string): string {
  let hash = 0;
  for (const ch of tag) hash = (hash * 31 + ch.charCodeAt(0)) | 0;
  return gradientStyles[Math.abs(hash) % gradientStyles.length];
}

function tagSize(count: number): string {
  const ratio = count / maxCount;
  return `${0.78 + ratio * 0.55}rem`;
}
---

<BaseLayout
  title="标签"
  description="按标签浏览文章。"
>
  <div class="container-blog py-12">
    <h1 class="mb-2 text-3xl font-bold tracking-tight text-gray-900 dark:text-gray-100">
      标签
    </h1>
    <p class="mb-10 text-sm text-gray-400 dark:text-gray-500">
      共 {tags.length} 个标签
    </p>

    {
      tags.length === 0 ? (
        <p class="text-sm text-gray-400">还没有标签。</p>
      ) : (
        <div class="flex flex-wrap items-center justify-center gap-3 py-8">
          {tags.map(({ tag, count }) => (
            <a
              href={`/tags/${tagSlug(tag)}/`}
              class="inline-flex items-center gap-1.5 rounded-full font-medium text-white no-underline shadow-sm transition-all duration-300 hover:scale-110 hover:shadow-lg hover:-translate-y-1"
              style={`${tagGradient(tag)} font-size: ${tagSize(count)}; padding: 0.5em 1em;`}
            >
              {tag}
              <span class="rounded-full bg-white/20 px-1.5 py-0.5 text-[0.65em] leading-none">{count}</span>
            </a>
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>
