---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getAllPosts } from "../../content/index.ts";

const posts = await getAllPosts();

// Group posts by year
const byYear = new Map<number, typeof posts>();
for (const post of posts) {
  const year = post.data.pubDate.getFullYear();
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(post);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<BaseLayout
  title="全部文章"
  description="所有已发布的文章列表。"
>
  <div class="container-blog py-12">
    <h1 class="mb-10 text-3xl font-bold tracking-tight text-gray-900 dark:text-gray-100">
      全部文章
    </h1>

    <section>
      {
        posts.length === 0 ? (
          <p class="text-sm text-gray-400">还没有文章。</p>
        ) : (
          years.map((year) => (
            <div class="mb-10">
              <!-- Year header -->
              <div class="mb-5 flex items-center gap-3">
                <span class="text-2xl font-bold text-gray-900 dark:text-gray-100">{year}</span>
                <span class="h-px flex-1 bg-gradient-to-r from-gray-200 to-transparent dark:from-gray-800"></span>
              </div>

              <!-- Timeline -->
              <div class="relative border-l-2 border-gray-200 pl-6 dark:border-gray-800">
                {byYear.get(year)!.map((post, i) => (
                  <div class="relative mb-6 last:mb-0">
                    <!-- Timeline dot -->
                    <div class="absolute -left-[calc(1.5rem+5px)] top-3 h-2.5 w-2.5 rounded-full border-2 border-accent bg-white dark:border-accent-dark dark:bg-gray-950"></div>
                    <PostCard post={post} index={i} />
                  </div>
                ))}
              </div>
            </div>
          ))
        )
      }
    </section>
  </div>
</BaseLayout>
